# OpenAI API Key (leave empty for mock mode — lab works fully without it)
OPENAI_API_KEY=""

# Model settings (used only in live mode)
OPENAI_MODEL=gpt-4o-mini

# Prompt quality threshold — minimum score (0.0-1.0) for a prompt to pass quality check
# Lower = more lenient, Higher = stricter
PROMPT_QUALITY_THRESHOLD=0.6

# Export format — yaml or markdown
EXPORT_FORMAT=yaml

# Service mode: mock (simulated responses) | llm (requires OPENAI_API_KEY)
RCA_MODE=mock
