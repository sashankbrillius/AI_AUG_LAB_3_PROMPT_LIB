  },
  "uid": "lab3-prompt-library",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Total HTTP requests per second to the prompt library gateway",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"prompt-library\"}[5m])) by (path)",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Endpoint",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "p95 and p50 response latency for the gateway",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service=\"prompt-library\"}[5m])) by (le))",
          "legendFormat": "Gateway p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{service=\"prompt-library\"}[5m])) by (le))",
          "legendFormat": "Gateway p50",
          "refId": "B"
        }
      ],
      "title": "Gateway Latency (p50 / p95)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "HTTP 5xx error rate percentage",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 0},
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"prompt-library\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{service=\"prompt-library\"}[5m]))",
          "legendFormat": "5xx Error %",
          "refId": "A"
        }
      ],
      "title": "Error Rate (5xx %)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Prompt test operations by category and result",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 15},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 7},
      "id": 4,
      "targets": [
        {
          "expr": "sum(prompt_tests_total{service=\"prompt-library\"}) by (category, result)",
          "legendFormat": "{{category}} ({{result}})",
          "refId": "A"
        }
      ],
      "title": "Prompt Tests by Category",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Prompt quality score distribution",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 15},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 7},
      "id": 5,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(prompt_quality_score_bucket{service=\"prompt-library\"}[5m])) by (le, category))",
          "legendFormat": "{{category}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(prompt_quality_score_bucket{service=\"prompt-library\"}[5m])) by (le, category))",
          "legendFormat": "{{category}} p95",
          "refId": "B"
        }
      ],
      "title": "Quality Score by Category (p50/p95)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Prompt category usage distribution",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 15},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 7},
      "id": 6,
      "targets": [
        {
          "expr": "sum(prompt_category_usage_total{service=\"prompt-library\"}) by (category)",
          "legendFormat": "{{category}}",
          "refId": "A"
        }
      ],
      "title": "Category Usage Distribution",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Estimated token usage — prompt vs completion",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 20, "stacking": {"mode": "normal"}},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 14},
      "id": 7,
      "targets": [
        {
          "expr": "sum(increase(prompt_token_estimate_total{service=\"prompt-library\",direction=\"prompt\"}[1h]))",
          "legendFormat": "Prompt tokens (1h)",
          "refId": "A"
        },
        {
          "expr": "sum(increase(prompt_token_estimate_total{service=\"prompt-library\",direction=\"completion\"}[1h]))",
          "legendFormat": "Completion tokens (1h)",
          "refId": "B"
        }
      ],
      "title": "Token Estimates (Cost Proxy)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Token burn rate per minute",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 15},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 14},
      "id": 8,
      "targets": [
        {
          "expr": "sum(rate(prompt_token_estimate_total{service=\"prompt-library\",direction=\"prompt\"}[5m])) * 60",
          "legendFormat": "Prompt tokens/min",
          "refId": "A"
        },
        {
          "expr": "sum(rate(prompt_token_estimate_total{service=\"prompt-library\",direction=\"completion\"}[5m])) * 60",
          "legendFormat": "Completion tokens/min",
          "refId": "B"
        }
      ],
      "title": "Token Burn Rate (per minute)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Library export operations by format",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 15},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 14},
      "id": 9,
      "targets": [
        {
          "expr": "sum(prompt_export_total{service=\"prompt-library\"}) by (format)",
          "legendFormat": "Export: {{format}}",
          "refId": "A"
        }
      ],
      "title": "Library Exports by Format",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Total prompts currently in the library",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "blue", "value": null},
